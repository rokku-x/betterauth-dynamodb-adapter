{
  "name": "betterauth-dynamodb-adapter",
  "version": "0.1.2",
  "description": "DynamoDB adapter for Better Auth — single-table design with full CRUD, filtering, and sorting support",
  "author": "rokku-x",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rokku-x/betterauth-dynamodb-adapter.git"
  },
  "bugs": {
    "url": "https://github.com/rokku-x/betterauth-dynamodb-adapter/issues"
  },
  "homepage": "https://github.com/rokku-x/betterauth-dynamodb-adapter#readme",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "keywords": [
    "better-auth",
    "betterauth",
    "dynamodb",
    "adapter",
    "auth",
    "authentication",
    "aws",
    "serverless",
    "single-table",
    "nosql",
    "database",
    "typescript"
  ],
  "scripts": {
    "build": "tsdown && tsc --emitDeclarationOnly --declaration --outDir dist",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --config eslint.config.ts src",
    "lint:fix": "eslint --config eslint.config.ts src --fix",
    "prepublishOnly": "npm run build",
    "prepack": "clean-package",
    "postpack": "clean-package restore",
    "changeset": "changeset",
    "version:changeset": "changeset version",
    "publish:changeset": "changeset publish"
  },
  "clean-package": {
    "remove": [
      "devDependencies",
      "scripts",
      "clean-package"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "aws-sdk-client-mock": "^4.1.0",
    "clean-package": "^2.2.0",
    "eslint": "^10.1.0",
    "jiti": "^2.6.1",
    "tsdown": "^0.21.7",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.57.2",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "better-auth": ">=1.0.0",
    "@aws-sdk/client-dynamodb": ">=3.0.0",
    "@aws-sdk/lib-dynamodb": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-dynamodb": {
      "optional": false
    },
    "@aws-sdk/lib-dynamodb": {
      "optional": false
    }
  }
}